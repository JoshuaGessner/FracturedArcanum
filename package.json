{
  "name": "fractured-arcanum",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:engine": "tsc -p tsconfig.engine.json",
    "server": "npm run build:engine && node server/server.js",
    "start": "node server/server.js",
    "dev:full": "npm run build:engine && concurrently \"npm run server\" \"npm run dev\"",
    "assets:generate": "node scripts/generate-brand-assets.mjs",
    "update:server": "bash scripts/update.sh",
    "update:server:dry": "bash scripts/update.sh --dry-run",
    "release:check": "npm test && npm run lint && npm run build",
    "build": "npm run build:engine && tsc -b && vite build",
    "lint": "eslint .",
    "pretest": "npm run build:engine",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
