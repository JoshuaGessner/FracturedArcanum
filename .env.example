PORT=43173
CLIENT_ORIGIN=http://localhost:5173
VITE_ARENA_URL=http://localhost:43173
# Recovery-only key. Regular admin access uses the owner/admin account session
# token. This key only grants access to POST /api/admin/owner/recover, which
# lets a server operator reset the owner account when no one can log in.
# Generated automatically on first launch and stored in
# arena-server-config.json; override here only if you need a fixed value.
ADMIN_KEY=change-me
ASSET_PROVIDER=local-svg
ASSET_API_KEY=
